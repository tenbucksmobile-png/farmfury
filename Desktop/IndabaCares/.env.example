# IndabaCares — Environment Variables
#
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must NEVER be committed to source control.
#
# These are EXPO_PUBLIC_ variables — they are embedded in the compiled app bundle
# at build time and are visible to anyone who unpacks the binary.
# This is intentional: Supabase's security model relies on Row Level Security (RLS)
# at the database layer, not on keeping the anon key secret.
#
# Secret keys (service_role, etc.) must ONLY be set in:
#   - Supabase Edge Function secrets (supabase secrets set KEY=value)
#   - EAS Secrets (eas secret:create --scope project --name KEY --value value)
# They must NEVER appear in this file or in any file committed to git.

# ─── Supabase ─────────────────────────────────────────────────────────────────

# Your Supabase project URL (found in: Supabase Dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (safe to embed in client — RLS enforces access)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── App Store / Play Store Reviewer Access ───────────────────────────────────
#
# Set these via EAS Secrets for review builds ONLY.
# Standard production builds must NOT set EXPO_PUBLIC_REVIEW_MODE=true.
# The demo account (DEMO01) is a real, limited employee in the production DB
# with no personal data — create it manually in the Supabase dashboard.
#
#   eas secret:create --scope project --name EXPO_PUBLIC_REVIEW_MODE  --value true
#   eas secret:create --scope project --name EXPO_PUBLIC_DEMO_CODE    --value DEMO01
#   eas secret:create --scope project --name EXPO_PUBLIC_DEMO_HOTEL   --value "Indaba Hotel"
#   eas secret:create --scope project --name EXPO_PUBLIC_DEMO_PASSWORD --value <password>
#
# For local testing only (never commit real credentials):
EXPO_PUBLIC_REVIEW_MODE=false
EXPO_PUBLIC_DEMO_CODE=DEMO01
EXPO_PUBLIC_DEMO_HOTEL=Indaba Hotel
EXPO_PUBLIC_DEMO_PASSWORD=

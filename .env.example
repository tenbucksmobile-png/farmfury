# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# cp .env.example .env
# ============================================================

# --- Binance API Keys ---
# Get these from: binance.com → Profile → API Management
# Enable: Read Info + Spot & Margin Trading
# Restrict to your VPS IP address for security
FREQTRADE__EXCHANGE__KEY=your_binance_api_key_here
FREQTRADE__EXCHANGE__SECRET=your_binance_secret_key_here

# --- Telegram Bot ---
# Step 1: Message @BotFather on Telegram → /newbot → copy the token
# Step 2: Message @userinfobot on Telegram → copy your chat_id
FREQTRADE__TELEGRAM__TOKEN=your_telegram_bot_token_here
FREQTRADE__TELEGRAM__CHAT_ID=your_telegram_chat_id_here

# --- FreqUI Dashboard (browser interface) ---
# Choose your own username and strong password
FREQTRADE__API_SERVER__USERNAME=admin
FREQTRADE__API_SERVER__PASSWORD=choose_a_strong_password_here

# --- Security Tokens (generate random strings, keep secret) ---
# Use: openssl rand -hex 32
FREQTRADE__API_SERVER__JWT_SECRET_KEY=replace_with_random_64_char_string
FREQTRADE__API_SERVER__WS_TOKEN=replace_with_random_32_char_string
